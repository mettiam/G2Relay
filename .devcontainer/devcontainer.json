{
  "name": "g2ray-lite-forwarder-go",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.23-bookworm",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "g2ray-lite-forwarder",
      "onAutoForward": "notify",
      "visibility": "public",
      "protocol": "http"
    }
  },
  "postStartCommand": "bash ./start.sh"
}
